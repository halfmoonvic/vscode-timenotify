{
  "name": "vscode-timenotify",
  "displayName": "TimeNotify",
  "description": "Status bar clock and scheduled reminders for VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Productivity"
  ],
  "keywords": [
    "time",
    "clock",
    "reminder",
    "notification",
    "productivity"
  ],
  "main": "./dist/src/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:timenotify.showNow"
  ],
  "contributes": {
    "commands": [
      {
        "command": "timenotify.showNow",
        "title": "TimeNotify: Show Current Time"
      }
    ],
    "configuration": {
      "title": "TimeNotify",
      "properties": {
        "timenotify.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TimeNotify reminders."
        },
        "timenotify.clockFormat": {
          "type": "string",
          "default": "ddd MM/DD HH:mm:ss",
          "description": "Status bar clock format."
        },
        "timenotify.statusBarAlignment": {
          "type": "string",
          "enum": ["left", "right"],
          "default": "right",
          "description": "Status bar alignment for the clock."
        },
        "timenotify.dedupeSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "Suppress duplicate reminders for the same event within this window."
        },
        "timenotify.notificationMode": {
          "type": "string",
          "enum": ["toast", "modal"],
          "default": "toast",
          "description": "Default reminder presentation mode."
        },
        "timenotify.snoozeMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Default snooze duration in minutes. Use 0 to disable snooze."
        },
        "timenotify.events": {
          "type": "array",
          "default": [],
          "description": "Reminder events.",
          "items": {
            "type": "object",
            "required": ["title", "date", "time"],
            "properties": {
              "title": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "description": "Supports YYYY/MM/DD, MM/DD, DD, Mon, Mon-Fri, Mon-Sun, Fri-Mon, Mon,Wed,Fri, everyday, workdays, weekends."
              },
              "time": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}:\\d{2}$",
                "description": "Must use HH:mm:ss."
              },
              "advanceMinutes": {
                "type": "number",
                "default": 0,
                "minimum": 0
              },
              "notificationMode": {
                "type": "string",
                "enum": ["toast", "modal"],
                "description": "Override the default reminder presentation mode for this event."
              },
              "snoozeMinutes": {
                "type": "number",
                "minimum": 0,
                "description": "Override the default snooze duration for this event. Use 0 to disable snooze."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"dist/test/**/*.test.js\"",
    "package:vsix": "npm run test && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.6.2"
  }
}
